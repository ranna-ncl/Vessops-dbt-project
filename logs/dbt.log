  left join map m
    on upper(trim(b.ship_cd)) = m.ship_cd_norm
)
select
  enriched.*,
  md5(upper(to_json(
    object_delete(object_construct_keep_null(*),
      'VOYAGE_CD',
      'SHIP_CD',
      'VESSEL_IMO'
    )
  ))) as hashdiff
from enriched
  );
