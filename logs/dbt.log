                'FISCAL_YEAR_NUMBER', 'ACCOUNTING_PERIOD', 'BUSINESS_UNIT_COMBINED_DESCRIPTION', 'OPERATING_UNIT_DESCRIPTION', 'SHIP_CD', 'M0_M1', 'VOYAGE_ID', 'ACCOUNT'
            )
        ))) as hashdiff
