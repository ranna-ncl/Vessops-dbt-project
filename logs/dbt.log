                'SHIP_NAME','SHIP_CD',
                'VESSEL_IMO',
                'SOURCE_FILE_NAME','SOURCE_FILE_ROW','LOAD_DTS','REC_SRC'
            )
        ))) as hashdiff
    from norm
)
select * from hd
  );
